                    "dynamodb:DescribeTable"
                ],
                "Resource": [
                    "arn:aws:dynamodb:us-east-1:303289350965:table/FusionInvoicesTable",
                    "arn:aws:dynamodb:us-east-1:303289350965:table/FusionInvoicesTable/index/*"
                ]
            }
        ]
    }
}
