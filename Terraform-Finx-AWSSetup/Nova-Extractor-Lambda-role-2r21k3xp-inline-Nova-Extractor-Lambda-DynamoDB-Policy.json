{
    "RoleName": "Nova-Extractor-Lambda-role-2r21k3xp",
    "PolicyName": "Nova-Extractor-Lambda-DynamoDB-Policy",
    "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Sid": "AllowFusionInvoicesTableAccess",
                "Effect": "Allow",
                "Action": [
                    "dynamodb:PutItem",
