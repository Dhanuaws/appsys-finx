{
    "RoleName": "email-attachment-parser-role-h9ukc1hg",
    "PolicyName": "S3ReadWriteEmailParserPolicy",
    "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Sid": "AllowBucketListing",
                "Effect": "Allow",
                "Action": "s3:ListBucket",
                "Resource": "arn:aws:s3:::amzn-s3-nova-bucket"
            },
            {
                "Sid": "AllowReadWriteInFolders",
                "Effect": "Allow",
                "Action": [
                    "s3:GetObject",
                    "s3:PutObject"
                ],
                "Resource": [
                    "arn:aws:s3:::amzn-s3-nova-bucket/raw-emails/*",
                    "arn:aws:s3:::amzn-s3-nova-bucket/email-attachment/*"
                ]
            }
        ]
    }
}
