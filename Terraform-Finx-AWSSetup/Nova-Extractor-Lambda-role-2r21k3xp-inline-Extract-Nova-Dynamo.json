{
    "RoleName": "Nova-Extractor-Lambda-role-2r21k3xp",
    "PolicyName": "Extract-Nova-Dynamo",
    "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Effect": "Allow",
                "Action": [
                    "s3:GetObject"
                ],
                "Resource": "arn:aws:s3:::email-attachment/*"
            },
            {
                "Effect": "Allow",
                "Action": [
                    "dynamodb:PutItem"
                ],
                "Resource": "arn:aws:dynamodb:us-east-1:303289350965:table/FusionInvoicesTable"
            },
            {
                "Effect": "Allow",
                "Action": [
                    "bedrock:InvokeModel",
                    "bedrock:InvokeModelWithResponseStream"
                ],
                "Resource": "*"
            }
        ]
    }
}
